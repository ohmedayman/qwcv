{
  "rules": {
    "users": {
      "$uid": {
        ".read": true,
        ".write": true,
        "cvs": {
          "$cvId": {
            ".validate": "newData.hasChildren(['name', 'data']) || newData.val() === null"
          }
        },
        "trash": {
          "$cvId": {
            ".validate": "newData.hasChildren(['data']) || newData.val() === null"
          }
        },
        "notifications": {
          "$notifId": {
            ".validate": "newData.hasChildren(['type', 'text', 'timestamp']) || newData.child('read').isBoolean()"
          }
        }
      }
    },
    "staff": {
      ".read": true,
      ".write": true
    },
    "subscriptions": {
      ".read": true,
      ".write": true,
      "$subId": {
        ".validate": "newData.hasChildren(['userId', 'plan', 'paymentMethod'])"
      }
    },
    "jobs": {
      ".read": true,
      ".write": true,
      "$jobId": {
        ".validate": "newData.hasChildren(['title', 'category'])"
      }
    },
    "domains": {
      ".read": true,
      ".write": true
    },
    "settings": {
      ".read": true,
      ".write": true
    },
    "siteSettings": {
      ".read": true,
      ".write": true
    },
    "portfolioLinks": {
      ".read": true,
      ".write": true,
      "$code": {
        ".validate": "newData.isString() && newData.val().length > 0"
      }
    },
    "messages": {
      ".read": true,
      ".write": true
    },
    "referrals": {
      ".read": true,
      ".write": true
    },
    "affiliateCampaigns": {
      ".read": true,
      ".write": true
    },
    "affiliateCommissions": {
      ".read": true,
      ".write": true
    },
    "analytics": {
      ".read": true,
      ".write": true
    },
    "approvedDomains": {
      ".read": true,
      ".write": true
    },
    "newsletter": {
      ".read": true,
      ".write": true,
      "$email": {
        ".validate": "newData.hasChildren(['email'])"
      }
    },
    "support": {
      ".read": true,
      ".write": true,
      "$ticketId": {
        ".validate": "newData.hasChildren(['userName', 'userEmail', 'message']) || newData.child('status').val() === 'closed' || newData.child('replies').exists()"
      }
    },
    "auditLog": {
      ".read": true,
      ".write": true
    },
    "affiliateRequests": {
      ".read": true,
      ".write": true
    },
    "pointsExchange": {
      ".read": true,
      ".write": true
    }
  }
}
